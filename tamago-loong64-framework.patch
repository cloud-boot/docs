diff --git a/loong64/loong64.s b/loong64/loong64.s
new file mode 100644
index 0000000..6a96766
--- /dev/null
+++ b/loong64/loong64.s
@@ -0,0 +1,30 @@
+#include "textflag.h"
+
+// Init is the bring-up entry. QEMU 'virt' enters a -kernel ELF in
+// direct-address (DA) mode (VA==PA), so for a first bring-up we enable the FPU
+// (LoongArch boots with it disabled), set the stack pointer (R3) to the top of
+// the RAM region, and enter the Go runtime.
+TEXT ·Init(SB),NOSPLIT|NOFRAME,$0
+	// enable the FPU: CSR.EUEN.FPE = 1 (EUEN is CSR 0x2). Go's loong64
+	// assembler has no csrwr mnemonic, so encode it directly:
+	//   csrwr R19, 0x2   =>  0x04000000 | (0x2<<10) | (1<<5) | 19
+	MOVV	$1, R19
+	WORD	$0x04000833
+
+	// install exception vector: CSR.EENTRY (0xc) = exceptionEntry
+	//   csrwr R12, 0xc  =>  0x04000000 | (0xc<<10) | (1<<5) | 12
+	MOVV	$·exceptionEntry(SB), R12
+	WORD	$0x0400302c
+
+	// set stack pointer to top of RAM minus the stack offset
+	MOVV	runtime∕goos·RamStart(SB), R3
+	MOVV	runtime∕goos·RamSize(SB), R19
+	MOVV	runtime∕goos·RamStackOffset(SB), R20
+	ADDV	R19, R3
+	SUBV	R20, R3
+	JMP	_rt0_tamago_start(SB)
+
+// func exit(int32)
+TEXT ·exit(SB),NOSPLIT,$0-8
+loop:
+	JMP	loop
