diff --git a/loong64/counter.go b/loong64/counter.go
new file mode 100644
index 0000000..28f8b8e
--- /dev/null
+++ b/loong64/counter.go
@@ -0,0 +1,28 @@
+// LoongArch stable-timer access (for monotonic time + RNG seeding).
+
+package loong64
+
+// counter returns the raw stable-timer counter (RDTIMED).
+func counter() int64
+
+// cpucfg returns CPUCFG[reg].
+func cpucfg(reg uint32) uint32
+
+// Counter returns the monotonic stable-timer counter.
+func Counter() int64 { return counter() }
+
+// CounterFreq returns the stable-timer frequency in Hz, derived from CPUCFG:
+// freq = cc_freq(word4) * cc_mul / cc_div (word5[15:0] / word5[31:16]).
+func CounterFreq() int64 {
+	base := int64(cpucfg(4))
+	if base == 0 {
+		return 100_000_000 // QEMU 'virt' default
+	}
+	cfg5 := cpucfg(5)
+	mul := int64(cfg5 & 0xffff)
+	div := int64((cfg5 >> 16) & 0xffff)
+	if mul == 0 || div == 0 {
+		return base
+	}
+	return base * mul / div
+}
diff --git a/loong64/counter.s b/loong64/counter.s
new file mode 100644
index 0000000..03d0074
--- /dev/null
+++ b/loong64/counter.s
@@ -0,0 +1,14 @@
+#include "textflag.h"
+
+// func counter() int64
+TEXT ·counter(SB),NOSPLIT,$0-8
+	RDTIMED	R0, R4
+	MOVV	R4, ret+0(FP)
+	RET
+
+// func cpucfg(reg uint32) uint32
+TEXT ·cpucfg(SB),NOSPLIT,$0-12
+	MOVW	reg+0(FP), R5
+	CPUCFG	R5, R4
+	MOVW	R4, ret+8(FP)
+	RET
diff --git a/loong64/exception.s b/loong64/exception.s
new file mode 100644
index 0000000..c32f5c2
--- /dev/null
+++ b/loong64/exception.s
@@ -0,0 +1,19 @@
+#include "textflag.h"
+
+// exceptionEntry is the CSR.EENTRY target. POC: announce a fault on the QEMU
+// 'virt' UART ("EXC\n") and halt — so exceptions are visible instead of a
+// silent jump to 0. A real port aligns this to 4 KiB, dispatches on ESTAT
+// (timer IRQ -> preempt; faults -> panic), and uses a registered console hook
+// instead of hardcoding the UART.
+TEXT ·exceptionEntry(SB),NOSPLIT|NOFRAME,$0
+	MOVV	$0x1fe001e0, R12
+	MOVV	$69, R13	// 'E'
+	MOVB	R13, (R12)
+	MOVV	$88, R13	// 'X'
+	MOVB	R13, (R12)
+	MOVV	$67, R13	// 'C'
+	MOVB	R13, (R12)
+	MOVV	$10, R13	// '\n'
+	MOVB	R13, (R12)
+halt:
+	JMP	halt
