+// cloud-boot UEFI carve-out: under -tags linkhwinit0 this file is
+// dropped so a board can provide its own goos.Hwinit0 linkname.
+// Mirrors the existing -tags linkcpuinit / linkramstart pattern.
+
+//go:build !linkhwinit0
+
 package arm64

 import (
